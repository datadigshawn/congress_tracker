# 複製成 .streamlit/secrets.toml（本機測試用），
# 或到 Streamlit Cloud → App → Settings → Secrets 貼上相同內容。
#
# 只有 private repo 或需要較高 API 額度時才需要 token；
# public repo 可以不填 token，直接下載。

[data_release]
repo  = "datadigshawn/congress_tracker"
tag   = "data-latest"
asset = "data.db"
# token = "ghp_xxxxxxxxxxxxxxxxxxxx"  # 可選
